{
    "app-id": "pl.ksefinvoice.KsefInvoice",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "KsefInvoice",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=network",
        "--device=dri"
    ],
    "modules": [
        {
            "name": "ksef-binary",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/lib/KsefInvoice /app/bin",
                "cp -r usr/bin/KsefInvoice/. /app/lib/KsefInvoice/",
                "rm -f /app/lib/KsefInvoice/_internal/libglib-2.0.so.0 /app/lib/KsefInvoice/_internal/libgobject-2.0.so.0 /app/lib/KsefInvoice/_internal/libgio-2.0.so.0 /app/lib/KsefInvoice/_internal/libgmodule-2.0.so.0 /app/lib/KsefInvoice/_internal/libgthread-2.0.so.0",
                "ln -sf /app/lib/KsefInvoice/KsefInvoice /app/bin/KsefInvoice",
                "install -Dm644 pl.ksefinvoice.KsefInvoice.metainfo.xml /app/share/metainfo/pl.ksefinvoice.KsefInvoice.metainfo.xml",
                "install -Dm644 pl.ksefinvoice.KsefInvoice.desktop /app/share/applications/pl.ksefinvoice.KsefInvoice.desktop",
                "install -Dm644 pl.ksefinvoice.KsefInvoice.png /app/share/icons/hicolor/128x128/apps/pl.ksefinvoice.KsefInvoice.png",
                "install -Dm644 LICENSE /app/share/licenses/pl.ksefinvoice.KsefInvoice/LICENSE"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/JDyszczynski/pl.ksefinvoice.app/releases/download/v1.0.33/KsefInvoice-1.0.33.tar.gz",
                    "sha256": "75fa357435c4722b46126920c8d8566e7b9af5a11943f7208543e4eef7cf6696",
                    "strip-components": 1
                }
            ]
        }
    ]
}